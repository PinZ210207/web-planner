@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile — Web Planner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css">
    <link rel="stylesheet" href="~/css/profile.css">
</head>
<body>

<aside class="sidebar">
  <div class="brand">
    <div class="brand-icon"><i class="ti ti-calendar-event"></i></div>
    <span class="brand-name">Web Planner</span>
  </div>
  <div class="nav-section">
    <p class="nav-label">Menu</p>
    <a href="/Tasks/Index" class="nav-link"><i class="ti ti-checklist"></i> My Tasks</a>
    <a href="/Tasks/Add" class="nav-link"><i class="ti ti-plus"></i> Add Task</a>
  </div>
  <div class="nav-section">
    <p class="nav-label">Filter</p>
    <a href="#" class="nav-link" data-filter="today"><i class="ti ti-calendar-day"></i> Today</a>
    <a href="#" class="nav-link" data-filter="week"><i class="ti ti-calendar-week"></i> This Week</a>
    <a href="#" class="nav-link" data-filter="high"><i class="ti ti-flag"></i> High Priority</a>
  </div>
  <div class="sidebar-footer">
    <div class="user-row">
      <div class="avatar" id="sidebar-avatar"></div>
      <div class="user-info">
        <div class="user-name" id="sidebar-name"></div>
        <div class="user-email" id="sidebar-email"></div>
      </div>
    </div>
    <a href="/Account/Profile" class="nav-link active" style="margin-top:4px;">
      <i class="ti ti-user"></i> Profile
    </a>
    <a href="/Account/Login" class="nav-link" id="logout-btn">
      <i class="ti ti-logout"></i> Sign out
    </a>
  </div>
</aside>

<main class="main">
  <div class="page-header">
    <h1 class="page-title">Profile</h1>
  </div>

  <div class="profile-layout">

    <div class="avatar-card">
      <div class="avatar-wrap">
        <div class="avatar-big" id="avatar-display"></div>
        <img id="avatar-img" src="" alt="Profile" style="display:none;">
        <button class="avatar-edit-btn" id="avatar-btn">
          <i class="ti ti-camera"></i>
        </button>
      </div>
      <input type="file" id="avatar-input" accept="image/*" style="display:none;">
      <h2 id="profile-fullname"></h2>
      <p id="profile-email-display"></p>
    </div>

    <div class="form-card">
      <h3 class="section-title">Personal information</h3>

      <div id="success-msg" class="success-msg" style="display:none;">
        <i class="ti ti-circle-check"></i> Profile updated successfully.
      </div>

      <div id="error-msg" class="error-msg" style="display:none;"></div>

      <div class="form-row">
        <div class="form-group">
          <label for="first-name">First name</label>
          <div class="field">
            <i class="ti ti-user"></i>
            <input type="text" id="first-name" placeholder="First name">
          </div>
        </div>
        <div class="form-group">
          <label for="last-name">Last name</label>
          <div class="field">
            <i class="ti ti-user"></i>
            <input type="text" id="last-name" placeholder="Last name">
          </div>
        </div>
      </div>

      <div class="form-group">
        <label for="email">Email address</label>
        <div class="field">
          <i class="ti ti-mail"></i>
          <input type="email" id="email" placeholder="Email address">
        </div>
      </div>

      <div class="form-actions">
        <button class="btn btn-primary" id="save-btn">
          <i class="ti ti-check"></i> Save changes
        </button>
      </div>
    </div>

  </div>
</main>

<script src="~/js/profile.js"></script>
</body>
</html>