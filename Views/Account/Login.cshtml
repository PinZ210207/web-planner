@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Web Planner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css">
    <link rel="stylesheet" href="~/css/login.css">
    
</head>
<body>
<div class="wrapper">

  <div class="left">
    <div class="brand">
      <div class="brand-icon"><i class="ti ti-calendar-event"></i></div>
      <span class="brand-name">Web Planner</span>
    </div>
    <div class="hero">
      <h2>Plan better.<br>Achieve more.</h2>
      <p>Organize your tasks, manage your time, and stay productive — all in one place.</p>
    </div>
    <div class="features">
      <div class="feature">
        <div class="feature-icon"><i class="ti ti-calendar-event"></i></div>
        <div class="feature-text"><h4>Smart Scheduling</h4><p>Plan your day with ease</p></div>
      </div>
      <div class="feature">
        <div class="feature-icon"><i class="ti ti-list-check"></i></div>
        <div class="feature-text"><h4>Stay Organized</h4><p>Keep everything in one place</p></div>
      </div>
      <div class="feature">
        <div class="feature-icon"><i class="ti ti-bell"></i></div>
        <div class="feature-text"><h4>Timely Reminders</h4><p>Never miss important tasks</p></div>
      </div>
    </div>
  </div>

  <div class="right">
    <div class="form-icon"><i class="ti ti-calendar-event"></i></div>
    <h1>Welcome back</h1>
    <p class="subheading">Sign in to your account to continue</p>

    <div class="form-group">
      <label for="email">Email address</label>
      <div class="field">
        <i class="ti ti-mail"></i>
        <input type="email" id="email" placeholder="name@example.com" autocomplete="email">
      </div>
    </div>

    <div class="form-group">
      <div class="row">
        <label for="password">Password</label>
      </div>
      <div class="field">
        <i class="ti ti-lock"></i>
        <input type="password" id="password" placeholder="Enter your password" autocomplete="current-password">
      </div>
    </div>

    <button class="btn">
      Sign in <i class="ti ti-arrow-right"></i>
    </button>

    <p class="footer">Don't have an account? <a href="/Account/Signup">Sign up</a></p>
  </div>



</div>
<script src="~/js/login.js"></script>
</body>
</html>